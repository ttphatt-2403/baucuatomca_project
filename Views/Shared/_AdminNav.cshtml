<style>
    /* Break out of Bootstrap container to use full viewport width */
    body .container { max-width: 100% !important; padding: 0 !important; margin: 0 !important; width: 100% !important; }
    body main.pb-3 { padding: 0 !important; }
    body .py-4 { padding-top: 0 !important; padding-bottom: 0 !important; }

    .admin-wrap { display: flex; gap: 0; min-height: calc(100vh - 56px); }
    .admin-sidebar {
        width: 220px; min-width: 220px;
        background: linear-gradient(180deg, #0d0d1a 0%, #0a0a14 100%);
        border-right: 1px solid #2a2a4a;
        padding: 24px 0;
        display: flex; flex-direction: column; gap: 4px;
    }
    .admin-sidebar .side-title {
        color: #FFD700; font-size: .7rem; font-weight: 700;
        letter-spacing: 2px; text-transform: uppercase;
        padding: 0 20px 12px; border-bottom: 1px solid #2a2a4a; margin-bottom: 8px;
    }
    .admin-sidebar a {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 20px; color: #999; text-decoration: none;
        font-size: .9rem; transition: all .2s; border-left: 3px solid transparent;
    }
    .admin-sidebar a:hover { color: #fff; background: rgba(255,215,0,.05); border-left-color: #FFD700; }
    .admin-sidebar a.active { color: #FFD700; background: rgba(255,215,0,.08); border-left-color: #FFD700; font-weight: 600; }
    .admin-sidebar a .icon { font-size: 1.1rem; width: 22px; text-align: center; }
    .admin-content { flex: 1; padding: 28px 32px; overflow-x: auto; }
</style>
<div class="admin-wrap">
    <div class="admin-sidebar">
        <div class="side-title">⚙️ Admin Panel</div>
        <a asp-controller="Admin" asp-action="Index" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <span class="icon">📊</span> Dashboard
        </a>
        <a asp-controller="Admin" asp-action="Users" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Users" || ViewContext.RouteData.Values["action"]?.ToString() == "EditUser" ? "active" : "")">
            <span class="icon">👥</span> Người dùng
        </a>
        <a asp-controller="Admin" asp-action="Rooms" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Rooms" ? "active" : "")">
            <span class="icon">🏠</span> Phòng chơi
        </a>
        <div style="margin-top:auto; padding: 20px 20px 0; border-top:1px solid #2a2a4a;">
            <a asp-controller="Room" asp-action="Index" style="color:#555; font-size:.82rem;">
                <span class="icon">←</span> Về trang chơi
            </a>
        </div>
    </div>
    <div class="admin-content">
