@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng ký - Bầu Cua Tôm Cá</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1a1a2e, #16213e); min-height: 100vh; display: flex; align-items: center; }
        .card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px); }
        .card-title { color: #ffd700; font-size: 2rem; }
        .btn-firebase { background: #ff6d00; color: #fff; border: none; }
        .btn-firebase:hover { background: #e65c00; color: #fff; }
        .btn-google { background: #fff; color: #444; border: 1px solid #ddd; font-weight: 500; }
        .btn-google:hover { background: #f5f5f5; }
        label { color: #ccc; }
        .divider { display: flex; align-items: center; gap: 10px; color: #666; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #444; }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow-lg p-4 rounded-4">
                <div class="text-center mb-4">
                    <img src="/images/logo.png.jpg" alt="BCTC88" style="width:150px;" class="mb-2" />
                    <p class="text-muted">Nhận ngay 100 xu miễn phí!</p>
                </div>
                <div id="errorMsg" class="alert alert-danger d-none"></div>
                <div id="successMsg" class="alert alert-success d-none"></div>

                <!-- Google Sign-In -->
                <button class="btn btn-google w-100 mb-3" onclick="registerWithGoogle()">
                    <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="20" class="me-2" />
                    Đăng ký với Google
                </button>

                <div class="divider mb-3">hoặc</div>

                <div class="mb-3">
                    <label>Tên hiển thị</label>
                    <input id="username" type="text" class="form-control bg-dark text-white border-secondary" placeholder="VD: ttphatt" maxlength="30" />
                </div>
                <div class="mb-3">
                    <label>Email</label>
                    <input id="email" type="email" class="form-control bg-dark text-white border-secondary" />
                </div>
                <div class="mb-3">
                    <label>Mật khẩu (tối thiểu 6 ký tự)</label>
                    <input id="password" type="password" class="form-control bg-dark text-white border-secondary" />
                </div>
                <button class="btn btn-firebase w-100 mb-3" onclick="register()">Tạo tài khoản</button>
                <hr class="border-secondary" />
                <p class="text-center text-muted mb-0">Đã có tài khoản? <a href="/Account/Login" class="text-warning">Đăng nhập</a></p>
            </div>
        </div>
    </div>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
    import { getAuth, createUserWithEmailAndPassword, signInWithPopup, GoogleAuthProvider } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

    const firebaseConfig = {
        apiKey: "@ViewData["FirebaseApiKey"]",
        authDomain: "@ViewData["FirebaseAuthDomain"]",
        projectId: "@ViewData["FirebaseProjectId"]"
    };
    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const googleProvider = new GoogleAuthProvider();

    async function sendTokenToServer(idToken) {
        const username = document.getElementById('username')?.value?.trim() || '';
        const res = await fetch('/Account/FirebaseCallback', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idToken, username })
        });
        if (res.ok) {
            const data = await res.json();
            const successEl = document.getElementById('successMsg');
            successEl.textContent = `Chào mừng ${data.username}! Số dư: ${data.balance} xu`;
            successEl.classList.remove('d-none');
            setTimeout(() => window.location.href = '/Room', 1200);
        } else {
            const data = await res.json();
            throw new Error(data.message || 'Xác thực thất bại');
        }
    }

    window.registerWithGoogle = async function () {
        const errorEl = document.getElementById('errorMsg');
        errorEl.classList.add('d-none');
        try {
            const cred = await signInWithPopup(auth, googleProvider);
            const idToken = await cred.user.getIdToken();
            await sendTokenToServer(idToken);
        } catch (err) {
            if (err.code !== 'auth/popup-closed-by-user') {
                errorEl.textContent = err.message;
                errorEl.classList.remove('d-none');
            }
        }
    };

    window.register = async function () {
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        const errorEl = document.getElementById('errorMsg');
        errorEl.classList.add('d-none');
        try {
            const cred = await createUserWithEmailAndPassword(auth, email, password);
            const idToken = await cred.user.getIdToken();
            await sendTokenToServer(idToken);
        } catch (err) {
            errorEl.textContent = err.message;
            errorEl.classList.remove('d-none');
        }
    };
</script>
</body>
</html>
