@model IEnumerable<BauCuaTomCa.Models.Bet>
@{
    ViewData["Title"] = "Lịch sử của tôi";
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var user = ViewBag.CurrentUser as BauCuaTomCa.Models.User;
    var symbolEmoji = new Dictionary<string, string>
    {
        ["Bau"] = "🎃", ["Cua"] = "🦀", ["Tom"] = "🦐",
        ["Ca"] = "🐟", ["Ga"] = "🐓", ["Nai"] = "🦌"
    };
    var diceEmoji = new Dictionary<string, string>
    {
        ["Bau"] = "🎃", ["Cua"] = "🦀", ["Tom"] = "🦐",
        ["Ca"] = "🐟", ["Ga"] = "🐓", ["Nai"] = "🦌"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-warning">📋 Lịch sử của tôi</h3>
    <a asp-controller="Room" asp-action="Index" class="btn btn-outline-warning">← Về phòng chơi</a>
</div>

<!-- Thống kê tổng quan -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-dark border-secondary text-center p-3">
            <div class="text-muted small">Số dư hiện tại</div>
            <div class="text-warning fs-4 fw-bold">@user?.Balance xu</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-secondary text-center p-3">
            <div class="text-muted small">Tổng lượt cược</div>
            <div class="text-white fs-4 fw-bold">@ViewBag.TotalBets</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-secondary text-center p-3">
            <div class="text-muted small">Tổng thắng</div>
            <div class="text-success fs-4 fw-bold">+@ViewBag.TotalWin xu</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-secondary text-center p-3">
            <div class="text-muted small">Tổng thua</div>
            <div class="text-danger fs-4 fw-bold">@ViewBag.TotalLoss xu</div>
        </div>
    </div>
</div>

<!-- Bảng lịch sử -->
@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🎯</div>
        <p class="mt-2">Chưa có lịch sử nào. Hãy vào chơi!</p>
    </div>
}
else
{
    <div class="card bg-dark border-secondary">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead class="border-secondary">
                    <tr>
                        <th class="text-warning">Phòng</th>
                        <th class="text-warning">Kết quả xúc xắc</th>
                        <th class="text-warning">Đặt cược</th>
                        <th class="text-warning">Xu cược</th>
                        <th class="text-warning">Kết quả</th>
                        <th class="text-warning">Thời gian</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bet in Model)
                    {
                        var isWin = bet.WinAmount > 0;
                        var d1 = bet.Round.Dice1?.ToString() ?? "?";
                        var d2 = bet.Round.Dice2?.ToString() ?? "?";
                        var d3 = bet.Round.Dice3?.ToString() ?? "?";
                        <tr>
                            <td>
                                <a asp-controller="History" asp-action="Room"
                                   asp-route-roomId="@bet.Round.RoomId"
                                   class="text-warning text-decoration-none">
                                    @bet.Round.Room?.Name
                                </a>
                            </td>
                            <td>
                                <span title="@d1">@(diceEmoji.GetValueOrDefault(d1, d1))</span>
                                <span title="@d2">@(diceEmoji.GetValueOrDefault(d2, d2))</span>
                                <span title="@d3">@(diceEmoji.GetValueOrDefault(d3, d3))</span>
                            </td>
                            <td>
                                @(symbolEmoji.GetValueOrDefault(bet.Symbol.ToString(), bet.Symbol.ToString()))
                                @bet.Symbol
                            </td>
                            <td class="text-white">@bet.Amount xu</td>
                            <td>
                                <span class="badge @(isWin ? "bg-success" : "bg-danger") fs-6">
                                    @(isWin ? "+" : "")@bet.WinAmount xu
                                </span>
                            </td>
                            <td class="text-muted small">
                                @bet.Round.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Phân trang -->
    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link bg-dark border-secondary text-warning"
                       asp-action="Index" asp-route-page="@(page - 1)">‹</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link @(i == page ? "bg-warning border-warning text-dark" : "bg-dark border-secondary text-warning")"
                           asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link bg-dark border-secondary text-warning"
                       asp-action="Index" asp-route-page="@(page + 1)">›</a>
                </li>
            </ul>
        </nav>
    }
}
