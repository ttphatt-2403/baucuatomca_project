@model BauCuaTomCa.Models.User
@{
    ViewData["Title"] = "Sửa người dùng";
}
@await Html.PartialAsync("_AdminNav")

<div class="mb-4">
    <a asp-action="Users" style="color:#555;text-decoration:none;font-size:.85rem;">← Quay lại danh sách</a>
    <h3 class="text-warning fw-bold mt-1 mb-0">Chỉnh sửa người dùng</h3>
    <small class="text-muted">ID #@Model.Id</small>
</div>

<div style="max-width:480px;">
    <!-- User info card -->
    <div style="background:#13132a;border:1px solid #2a2a4a;border-radius:14px;padding:20px;margin-bottom:20px;display:flex;align-items:center;gap:16px;">
        <div style="width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#2a1a6e,#1a2a6e);display:flex;align-items:center;justify-content:center;font-weight:700;color:#a78bfa;font-size:1.3rem;flex-shrink:0;">
            @Model.Username.Substring(0, 1).ToUpper()
        </div>
        <div>
            <div style="color:#fff;font-weight:600;">@Model.Username</div>
            <div style="color:#555;font-size:.82rem;">@(string.IsNullOrEmpty(Model.Email) ? "Chưa có email" : Model.Email)</div>
        </div>
        @if (Model.IsAdmin)
        {
            <span style="margin-left:auto;background:rgba(255,215,0,.15);color:#FFD700;font-size:.72rem;font-weight:700;padding:3px 10px;border-radius:20px;">ADMIN</span>
        }
    </div>

    <!-- Edit Form -->
    <div style="background:#0f0f20;border:1px solid #1e1e35;border-radius:14px;padding:24px;">
        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:rgba(255,107,107,.1);border:1px solid rgba(255,107,107,.3);border-radius:10px;padding:12px;margin-bottom:20px;color:#ff6b6b;font-size:.85rem;">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>⚠️ @err.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="EditUser" asp-route-id="@Model.Id" method="post">
            <div class="mb-4">
                <label style="color:#888;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Username</label>
                <input type="text" name="username" value="@Model.Username" required maxlength="50"
                       style="width:100%;background:#13132a;color:#fff;border:1px solid #2a2a4a;border-radius:10px;padding:10px 14px;margin-top:6px;outline:none;transition:border .2s;"
                       onfocus="this.style.borderColor='#FFD700'" onblur="this.style.borderColor='#2a2a4a'" />
            </div>

            <div class="mb-4">
                <label style="color:#888;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Số dư (xu)</label>
                <div style="position:relative;margin-top:6px;">
                    <input type="number" name="balance" value="@Model.Balance" min="0" step="1" required
                           style="width:100%;background:#13132a;color:#FFD700;border:1px solid #2a2a4a;border-radius:10px;padding:10px 50px 10px 14px;outline:none;font-weight:600;transition:border .2s;"
                           onfocus="this.style.borderColor='#FFD700'" onblur="this.style.borderColor='#2a2a4a'" />
                    <span style="position:absolute;right:14px;top:50%;transform:translateY(-50%);color:#555;font-size:.82rem;">xu</span>
                </div>
                <!-- Quick set buttons -->
                <div class="d-flex gap-2 mt-2">
                    @foreach (var amount in new[] { 100, 500, 1000, 5000 })
                    {
                        <button type="button" onclick="document.querySelector('[name=balance]').value=@amount"
                                style="background:#1e1e35;color:#888;border:1px solid #2a2a4a;border-radius:8px;padding:3px 10px;font-size:.75rem;cursor:pointer;">
                            @amount
                        </button>
                    }
                </div>
            </div>

            <div class="mb-5">
                <label style="color:#888;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Quyền hạn</label>
                <div style="margin-top:10px;">
                    <label style="display:flex;align-items:center;gap:12px;cursor:pointer;background:#13132a;border:1px solid #2a2a4a;border-radius:10px;padding:12px 16px;">
                        <input type="checkbox" name="isAdmin" value="true" @(Model.IsAdmin ? "checked" : "")
                               style="width:18px;height:18px;accent-color:#FFD700;" />
                        <div>
                            <div style="color:#fff;font-weight:500;">Quyền Admin</div>
                            <div style="color:#555;font-size:.78rem;">Có thể truy cập trang quản trị</div>
                        </div>
                    </label>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit"
                        style="flex:1;background:linear-gradient(135deg,#FFD700,#B8860B);color:#000;font-weight:700;border:none;border-radius:10px;padding:12px;font-size:.95rem;cursor:pointer;transition:opacity .2s;"
                        onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
                    💾 Lưu thay đổi
                </button>
                <a asp-action="Users"
                   style="padding:12px 20px;background:#13132a;color:#888;border:1px solid #2a2a4a;border-radius:10px;text-decoration:none;font-size:.9rem;display:flex;align-items:center;">
                    Huỷ
                </a>
            </div>
        </form>
    </div>
</div>

    </div>
</div>
