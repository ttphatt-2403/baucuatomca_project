@model IEnumerable<BauCuaTomCa.Models.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    int totalCount = ViewBag.TotalCount;
    int page = ViewBag.Page;
    int pageSize = ViewBag.PageSize;
    int totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-warning">👥 Người dùng (@totalCount)</h2>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Dashboard</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search -->
<form method="get" class="mb-3 d-flex gap-2">
    <input name="search" value="@ViewBag.Search" class="form-control bg-dark text-white border-secondary" style="max-width:300px;" placeholder="Tìm theo tên / email..." />
    <button class="btn btn-warning">Tìm</button>
    @if (!string.IsNullOrEmpty(ViewBag.Search as string))
    {
        <a asp-action="Users" class="btn btn-outline-secondary">Xoá lọc</a>
    }
</form>

<div class="table-responsive">
    <table class="table table-dark table-hover align-middle">
        <thead style="color:#FFD700;">
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Số dư (xu)</th>
                <th>Admin</th>
                <th>Ngày tạo</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td class="text-muted">@user.Id</td>
                    <td>
                        @user.Username
                        @if (user.IsAdmin)
                        {
                            <span class="badge bg-warning text-dark ms-1">Admin</span>
                        }
                    </td>
                    <td class="text-muted">@user.Email</td>
                    <td style="color:#FFD700;">@user.Balance.ToString("N0")</td>
                    <td>
                        @if (user.IsAdmin)
                        {
                            <span class="text-warning">✓</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-muted" style="font-size:.85rem;">@user.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning">✏️ Sửa</a>
                            @if (user.Id.ToString() != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                            {
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post"
                                      onsubmit="return confirm('Xác nhận xoá @user.Username?')">
                                    <button class="btn btn-sm btn-outline-danger">🗑 Xoá</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link bg-dark border-secondary text-white" asp-action="Users"
                       asp-route-page="@i" asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}
