@model IEnumerable<BauCuaTomCa.Models.Room>
@{
    ViewData["Title"] = "Quản lý phòng";
}
@await Html.PartialAsync("_AdminNav")

@if (TempData["Success"] != null)
{
    <div class="alert alert-dismissible border-0 mb-4" style="background:rgba(0,255,136,.1);color:#00ff88;">
        @TempData["Success"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="text-warning fw-bold mb-0">Phòng chơi</h3>
        <small class="text-muted">@Model.Count() phòng</small>
    </div>
</div>

<div style="background:#0f0f20;border:1px solid #1e1e35;border-radius:14px;overflow:hidden;">
    <table class="table mb-0 align-middle" style="color:#ccc;">
        <thead>
            <tr style="background:#13132a;border-bottom:1px solid #2a2a4a;">
                <th class="px-4 py-3" style="color:#FFD700;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;width:50px;">ID</th>
                <th class="py-3" style="color:#FFD700;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Tên phòng</th>
                <th class="py-3" style="color:#FFD700;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Trạng thái</th>
                <th class="py-3" style="color:#FFD700;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Người chơi</th>
                <th class="py-3" style="color:#FFD700;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Vòng</th>
                <th class="py-3" style="color:#FFD700;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Tạo lúc</th>
                <th class="py-3 pe-4 text-end" style="color:#FFD700;font-size:.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                var dotColor = room.Status == BauCuaTomCa.Models.RoomStatus.Betting ? "#00ff88" : room.Status == BauCuaTomCa.Models.RoomStatus.Revealing ? "#FFD700" : room.Status == BauCuaTomCa.Models.RoomStatus.Finished ? "#ff6b6b" : "#888";
                var statusLabel = room.Status == BauCuaTomCa.Models.RoomStatus.Betting ? "Đặt cược" : room.Status == BauCuaTomCa.Models.RoomStatus.Revealing ? "Mở bài" : room.Status == BauCuaTomCa.Models.RoomStatus.Finished ? "Kết thúc" : "Chờ";
                var statusBg = room.Status == BauCuaTomCa.Models.RoomStatus.Betting ? "rgba(0,255,136,.12)" : room.Status == BauCuaTomCa.Models.RoomStatus.Revealing ? "rgba(255,215,0,.12)" : room.Status == BauCuaTomCa.Models.RoomStatus.Finished ? "rgba(255,107,107,.12)" : "rgba(100,100,100,.15)";
                <tr style="border-bottom:1px solid #1a1a2e;" onmouseover="this.style.background='#13132a'" onmouseout="this.style.background='transparent'">
                    <td class="px-4" style="color:#444;font-size:.82rem;">@room.Id</td>
                    <td>
                        <div style="color:#fff;font-weight:500;">@room.Name</div>
                        <div style="color:#555;font-size:.78rem;">Tối đa @room.MaxPlayers người</div>
                    </td>
                    <td>
                        <span style="background:@statusBg;color:@dotColor;font-size:.75rem;font-weight:600;padding:3px 10px;border-radius:20px;letter-spacing:.5px;">
                            @statusLabel
                        </span>
                    </td>
                    <td>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var p in room.RoomPlayers)
                            {
                                <span style="background:#1e1e35;color:#a78bfa;font-size:.75rem;padding:2px 8px;border-radius:20px;border:1px solid #2a2a4a;">@p.User?.Username</span>
                            }
                            @if (!room.RoomPlayers.Any()) { <span style="color:#444;font-size:.78rem;">Trống</span> }
                        </div>
                    </td>
                    <td>
                        <span style="color:#888;">@room.Rounds.Count</span>
                    </td>
                    <td style="color:#555;font-size:.82rem;">@room.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                    <td class="text-end pe-4">
                        <form asp-action="DeleteRoom" asp-route-id="@room.Id" method="post"
                              onsubmit="return confirm('Xác nhận xoá phòng @room.Name?')">
                            <button type="submit"
                                    style="background:#1e1520;color:#ff6b6b;border:1px solid #2a1a1a;border-radius:8px;padding:5px 14px;font-size:.82rem;transition:all .2s;"
                                    onmouseover="this.style.borderColor='#ff6b6b'" onmouseout="this.style.borderColor='#2a1a1a'">
                                🗑 Xoá
                            </button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center py-5" style="color:#444;">Chưa có phòng nào</td>
                </tr>
            }
        </tbody>
    </table>
</div>

    </div>
</div>
